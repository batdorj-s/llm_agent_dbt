# ─────────────────────────────────────────────────────────────────────────────
# Шинжээч.ai — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider API Keys (at least ONE required) ────────────────────────────
# Free tier: Groq (14,400 req/day) → https://console.groq.com/keys
#            Google AI Studio (1,500 req/day) → https://aistudio.google.com/app/apikey
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Semantic Search Embeddings ──────────────────────────────────────────────────
# Gemini text-embedding model for hybrid semantic search (BM25 + vector)
# Free tier: 1,500 requests/day via Google AI Studio (same key as GOOGLE_API_KEY)
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/postgres
DBT_PASSWORD=your_postgres_password

# ChromaDB vector store (required for RAG / knowledge base)
CHROMA_URL=http://localhost:8000

# Supabase (optional — only for hosted production Postgres)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_at_least_32_chars_long_change_this
JWT_EXPIRES_IN=8h

# Admin account (created on first boot)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_strong_password

# Set true only to reset admin password on restart (keep false in production)
RESET_ADMIN_ON_BOOT=false

# ── Observability (optional) ──────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Code Execution Sandbox ────────────────────────────────────────────────────
# E2B secure Python sandbox — https://e2b.dev
# Falls back to local python3 subprocess (less secure) if not set
E2B_API_KEY=your_e2b_api_key_here

# ── Server Config ─────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# In Docker Compose: set to http://api:3001 (internal service name)
# In standalone: set to your public API domain
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Redis Rate Limiter (recommended for multi-instance production) ─────────────
# Without Redis, falls back to per-instance in-memory rate limiting
# REDIS_URL=redis://localhost:6379

# ── MCP ───────────────────────────────────────────────────────────────────────
MCP_USER_ID=system
