FROM node:20-alpine AS deps
WORKDIR /app
COPY package*.json ./
# Install all deps (including tsx for runtime transpilation)
RUN npm ci

FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production

COPY --from=deps /app/node_modules ./node_modules
COPY package.json ./
COPY src/ ./src/
COPY config/ ./config/
COPY dbt/ ./dbt/

EXPOSE 3001
CMD ["node_modules/.bin/tsx", "src/api-server.ts"]
